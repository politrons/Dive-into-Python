# Optional. Restricts all Git MCP operations to this directory tree.
MCP_GIT_BASE_DIR=/Users/politrons/development/Dive-into-Python

# Optional. Restricts Filesystem MCP read/write operations to this directory tree.
MCP_FILESYSTEM_ROOT=/Users/politrons/development/Dive-into-Python

# Optional. Needed only when your remote uses SSH and the shell does not expose it.
SSH_AUTH_SOCK=

# Optional. Keep false unless your local git signing is configured.
GIT_SIGN_COMMITS=false
